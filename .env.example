# Copy this file to `.env` and fill in your personal values.
# `.env` is gitignored; never commit it.
#
# HuggingFace access token for pyannote.audio diarization.
# Required only when running with `--diarize`.
# Get one at: https://huggingface.co/settings/tokens
# You must also accept the user conditions for every gated model used by
# pyannote.audio (each one is a separate "Agree and access" page on HF):
#   - https://huggingface.co/pyannote/segmentation-3.0
#   - https://huggingface.co/pyannote/speaker-diarization-3.1
#   - https://huggingface.co/pyannote/speaker-diarization-community-1
# The last one is required by pyannote.audio >= 4.0, which loads PLDA weights
# from that repository even when the configured model is speaker-diarization-3.1.
HF_TOKEN="hf..."
